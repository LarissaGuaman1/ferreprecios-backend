PORT=3000

# Cadena de conexión de tu cluster de MongoDB Atlas.
MONGODB_URI=mongodb+srv://usuario:password@tu-cluster.mongodb.net/ferreprecios

# Cualquier texto largo y secreto que se te ocurra (se usa para firmar los tokens de login).
JWT_SECRET=

# Credenciales de tu cuenta de Cloudinary (cloudinary.com), para subir las fotos.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
